{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": true,
		"target": "ES2020",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": false,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"$lib": ["src/lib"],
			"$lib/*": ["src/lib/*"],
			"$app/*": [".svelte-kit/runtime/app/*"]
		}
	},
	"include": ["src/**/*.js", "src/**/*.ts", "src/**/*.svelte"],
	"exclude": ["node_modules", "build", ".svelte-kit/build"]
}
